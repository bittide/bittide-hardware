"""TUI to build a debug.json subset of all.json for synthesis runs."""

import curses
import json
import os
import subprocess
import sys
from pathlib import Path

os.environ.setdefault("ESCDELAY", "25")

STAGES = ["hdl", "pnr", "bitstream", "test"]


def repo_root() -> Path:
    out = subprocess.check_output(["git", "rev-parse", "--show-toplevel"])
    return Path(out.decode().strip())


def load_all(path: Path) -> list[dict]:
    with path.open() as f:
        return json.load(f)


def load_debug(path: Path) -> dict[str, dict]:
    """Return mapping from top name to {stage, cc_report} for prefill."""
    if not path.exists():
        return {}
    with path.open() as f:
        data = json.load(f)
    return {e["top"]: {"stage": e["stage"], "cc_report": e["cc_report"]} for e in data}


def write_debug(path: Path, entries: list[dict], all_entries: list[dict]) -> None:
    # Match formatting of all.json: one entry per line, columns aligned to
    # widest top/stage across all.json so debug.json stays visually consistent.
    if not entries:
        path.write_text("[]\n")
        return
    top_w = max(len(e["top"]) for e in all_entries) + 3
    stage_w = max(len(s) for s in STAGES) + 3
    lines = ["["]
    for i, e in enumerate(entries):
        top_field = f'"{e["top"]}",'.ljust(top_w)
        stage_field = f'"{e["stage"]}",'.ljust(stage_w)
        cc = "true" if e["cc_report"] else "false"
        sep = "," if i < len(entries) - 1 else ""
        lines.append(
            f'  {{"top": {top_field} "stage": {stage_field} "cc_report": {cc}}}{sep}'
        )
    lines.append("]")
    path.write_text("\n".join(lines) + "\n")


def max_stage_idx(all_stage: str) -> int:
    return STAGES.index(all_stage)


class App:
    def __init__(self, all_path: Path, debug_path: Path):
        self.all_path = all_path
        self.debug_path = debug_path
        self.all_entries = sorted(load_all(all_path), key=lambda e: e["top"])
        prefill = load_debug(debug_path)
        # Per-row state: selected flag, current stage idx, cc_report flag.
        self.rows = []
        for e in self.all_entries:
            top = e["top"]
            max_idx = max_stage_idx(e["stage"])
            if top in prefill:
                pre = prefill[top]
                stage_idx = STAGES.index(pre["stage"]) if pre["stage"] in STAGES else max_idx
                stage_idx = min(stage_idx, max_idx)
                self.rows.append({
                    "selected": True,
                    "stage_idx": stage_idx,
                    "max_stage_idx": max_idx,
                    "cc_report": pre["cc_report"],
                })
            else:
                self.rows.append({
                    "selected": False,
                    "stage_idx": max_idx,
                    "max_stage_idx": max_idx,
                    "cc_report": e["cc_report"],
                })
        self.cursor = 0
        self.scroll = 0
        self.status = ""
        self.num_buf = ""
        self.filter = ""
        self.searching = False

    def visible_indices(self) -> list[int]:
        if not self.filter:
            return list(range(len(self.rows)))
        needle = self.filter.lower()
        return [
            i for i, e in enumerate(self.all_entries) if needle in e["top"].lower()
        ]

    def selected_entries(self) -> list[dict]:
        out = []
        for src, row in zip(self.all_entries, self.rows):
            if row["selected"]:
                out.append({
                    "top": src["top"],
                    "stage": STAGES[row["stage_idx"]],
                    "cc_report": row["cc_report"],
                })
        return out

    def save(self) -> None:
        write_debug(self.debug_path, self.selected_entries(), self.all_entries)
        self.status = f"Saved {len(self.selected_entries())} entries to {self.debug_path}"

    def current_row_idx(self) -> int | None:
        vis = self.visible_indices()
        if not vis:
            return None
        self.cursor = max(0, min(len(vis) - 1, self.cursor))
        return vis[self.cursor]

    def toggle(self) -> None:
        idx = self.current_row_idx()
        if idx is None:
            return
        self.rows[idx]["selected"] = not self.rows[idx]["selected"]
        self.save()

    def toggle_cc(self) -> None:
        idx = self.current_row_idx()
        if idx is None:
            return
        self.rows[idx]["cc_report"] = not self.rows[idx]["cc_report"]
        self.save()

    def cycle_stage(self, delta: int) -> None:
        idx = self.current_row_idx()
        if idx is None:
            return
        row = self.rows[idx]
        new_idx = row["stage_idx"] + delta
        if 0 <= new_idx <= row["max_stage_idx"]:
            row["stage_idx"] = new_idx
            self.save()

    def move(self, delta: int) -> None:
        n = len(self.visible_indices())
        if n == 0:
            self.cursor = 0
            return
        self.cursor = max(0, min(n - 1, self.cursor + delta))

    def draw(self, stdscr) -> None:
        stdscr.erase()
        h, w = stdscr.getmaxyx()
        title = (
            f" debug.json builder  ({len(self.selected_entries())}/{len(self.rows)} selected) "
        )
        stdscr.addnstr(0, 0, title.ljust(w), w, curses.A_REVERSE)
        help_line = (
            " space:toggle  c:cc_report  ←/→:stage  ↑/↓:move  /:search  #<enter>:jump+toggle  q:quit "
        )
        stdscr.addnstr(1, 0, help_line[:w], w)

        list_top = 3
        list_bottom = h - 2
        visible = list_bottom - list_top

        vis = self.visible_indices()
        if vis:
            self.cursor = max(0, min(len(vis) - 1, self.cursor))
        else:
            self.cursor = 0
        if self.cursor < self.scroll:
            self.scroll = self.cursor
        elif self.cursor >= self.scroll + visible:
            self.scroll = self.cursor - visible + 1
        self.scroll = max(0, min(self.scroll, max(0, len(vis) - visible)))

        top_w = max(len(e["top"]) for e in self.all_entries)
        num_w = len(str(len(self.rows)))
        for i in range(visible):
            vis_pos = self.scroll + i
            if vis_pos >= len(vis):
                break
            idx = vis[vis_pos]
            src = self.all_entries[idx]
            row = self.rows[idx]
            mark = "[x]" if row["selected"] else "[ ]"
            stage = STAGES[row["stage_idx"]]
            max_stage = STAGES[row["max_stage_idx"]]
            cc = "cc" if row["cc_report"] else "  "
            stage_disp = f"{stage:<9} (max {max_stage})"
            num = f"{idx + 1:>{num_w}}"
            line = f" {num}  {mark}  {src['top']:<{top_w}}  {stage_disp}  {cc} "
            attr = curses.A_REVERSE if vis_pos == self.cursor else curses.A_NORMAL
            if row["selected"]:
                attr |= curses.A_BOLD | curses.color_pair(1)
            stdscr.addnstr(list_top + i, 0, line.ljust(w), w, attr)

        # Avoid writing into the bottom-right cell — curses errors when the
        # cursor would advance past the screen edge.
        last = max(0, w - 1)
        if self.num_buf:
            footer = f":{self.num_buf}"
        elif self.searching or self.filter:
            suffix = "" if self.searching else f"  ({len(vis)} match{'es' if len(vis) != 1 else ''})"
            footer = f"/{self.filter}{suffix}"
        else:
            footer = self.status
        stdscr.addnstr(h - 1, 0, footer[:last].ljust(last), last)
        stdscr.refresh()

    def run(self, stdscr) -> None:
        curses.curs_set(0)
        try:
            curses.start_color()
            curses.use_default_colors()
            curses.init_pair(1, curses.COLOR_GREEN, -1)
        except curses.error:
            pass
        stdscr.keypad(True)
        while True:
            self.draw(stdscr)
            ch = stdscr.getch()

            if self.searching:
                if ch == 27:
                    self.filter = ""
                    self.searching = False
                    self.cursor = 0
                    self.scroll = 0
                elif ch in (curses.KEY_ENTER, 10, 13):
                    self.searching = False
                elif ch in (curses.KEY_BACKSPACE, 127, 8):
                    if self.filter:
                        self.filter = self.filter[:-1]
                        self.cursor = 0
                        self.scroll = 0
                    else:
                        self.searching = False
                elif ch == ord(" "):
                    self.toggle()
                elif ch in (curses.KEY_UP,):
                    self.move(-1)
                elif ch in (curses.KEY_DOWN,):
                    self.move(1)
                elif ch == curses.KEY_PPAGE:
                    self.move(-10)
                elif ch == curses.KEY_NPAGE:
                    self.move(10)
                elif ch == curses.KEY_LEFT:
                    self.cycle_stage(-1)
                elif ch == curses.KEY_RIGHT:
                    self.cycle_stage(1)
                elif 32 < ch < 127:
                    self.filter += chr(ch)
                    self.cursor = 0
                    self.scroll = 0
                continue

            if ch == ord("/"):
                self.searching = True
                continue
            if ord("0") <= ch <= ord("9"):
                self.num_buf += chr(ch)
                continue
            if ch in (curses.KEY_BACKSPACE, 127, 8) and self.num_buf:
                self.num_buf = self.num_buf[:-1]
                continue
            if ch in (curses.KEY_ENTER, 10, 13) and self.num_buf:
                n = int(self.num_buf)
                self.num_buf = ""
                vis = self.visible_indices()
                target = n - 1
                if target in vis:
                    self.cursor = vis.index(target)
                    self.toggle()
                else:
                    self.status = f"line {n} not in view"
                continue
            if ch == 27 and self.num_buf:
                self.num_buf = ""
                continue
            if ch == 27 and self.filter:
                self.filter = ""
                self.cursor = 0
                self.scroll = 0
                continue
            if ch in (ord("q"), 27):
                return
            elif ch in (curses.KEY_UP, ord("k")):
                self.move(-1)
            elif ch in (curses.KEY_DOWN, ord("j")):
                self.move(1)
            elif ch == curses.KEY_PPAGE:
                self.move(-10)
            elif ch == curses.KEY_NPAGE:
                self.move(10)
            elif ch == ord(" "):
                self.toggle()
            elif ch == ord("c"):
                self.toggle_cc()
            elif ch in (curses.KEY_LEFT, ord("h")):
                self.cycle_stage(-1)
            elif ch in (curses.KEY_RIGHT, ord("l")):
                self.cycle_stage(1)


def git_change_kind(root: Path, path: Path) -> str | None:
    """Return 'add' if untracked, 'edit' if modified, None if unchanged."""
    rel = path.relative_to(root)
    status = subprocess.run(
        ["git", "status", "--porcelain", "--", str(rel)],
        cwd=root,
        capture_output=True,
        text=True,
        check=True,
    ).stdout
    if not status.strip():
        return None
    code = status[:2]
    if "?" in code:
        return "add"
    return "edit"


def offer_commit(root: Path, debug_path: Path) -> None:
    kind = git_change_kind(root, debug_path)
    if kind is None:
        return
    verb = "Add" if kind == "add" else "Edit"
    msg = f"TMP: {verb} debug.json"
    try:
        answer = input(f"Commit '{msg}'? [y/N] ").strip().lower()
    except EOFError:
        answer = ""
    if answer not in ("y", "yes"):
        return
    rel = str(debug_path.relative_to(root))
    subprocess.run(["git", "add", "--", rel], cwd=root, check=True)
    subprocess.run(["git", "commit", "-m", msg, "--", rel], cwd=root, check=True)


def main() -> int:
    root = repo_root()
    all_path = root / ".github" / "synthesis" / "all.json"
    debug_path = root / ".github" / "synthesis" / "debug.json"
    if not all_path.exists():
        print(f"error: {all_path} not found", file=sys.stderr)
        return 1
    app = App(all_path, debug_path)
    curses.wrapper(app.run)
    offer_commit(root, debug_path)
    return 0


if __name__ == "__main__":
    sys.exit(main())
